{
  "expo": {
    "name": "boaconsulta",
    "slug": "boaconsulta",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icone_boaconsulta.png",
    "scheme": "boaconsulta",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/icone_boaconsulta.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icone_boaconsulta.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "O BoaConsulta acessa suas fotos para permitir atualizar sua imagem de perfil."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#004ac6",
          "defaultChannel": "lembretes-atendimentos"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
